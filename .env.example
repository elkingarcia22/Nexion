# =============================================================================
# NEXIÓN — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file with real secrets to the repository.
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE
# Required from: Release 1 (auth + database)
# Source: Supabase project dashboard → Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=

# Only needed if running migrations via CLI locally
# SUPABASE_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# GOOGLE OAUTH
# Required from: Release 1 (login with Google)
# Source: Google Cloud Console → APIs & Services → Credentials
# Status: pending_creation
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Redirect URL for Supabase Auth (match exactly in Google Console)
# Example: https://your-project.supabase.co/auth/v1/callback
SUPABASE_AUTH_REDIRECT_URL=

# -----------------------------------------------------------------------------
# GEMINI AI
# Required from: Release 1 (source analysis)
# Source: Google AI Studio → API Keys
# Status: pending_creation
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash

# -----------------------------------------------------------------------------
# N8N CLOUD
# Required from: Release 1 (automation orchestration)
# Source: n8n Cloud → Settings → API Keys
# Status: available (keep key private, rotate if exposed)
# -----------------------------------------------------------------------------
N8N_BASE_URL=
N8N_API_KEY=

# -----------------------------------------------------------------------------
# APP
# Required from: Release 1
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# GOOGLE APIs (Google Drive, Docs, Sheets, Calendar)
# Required from: Release 3+ (integrations)
# Source: Same Google Cloud project as OAuth — additional scopes
# Status: planned / pending_setup
# -----------------------------------------------------------------------------
# GOOGLE_DRIVE_SCOPE=https://www.googleapis.com/auth/drive.readonly
# GOOGLE_DOCS_SCOPE=https://www.googleapis.com/auth/documents.readonly
# GOOGLE_SHEETS_SCOPE=https://www.googleapis.com/auth/spreadsheets.readonly
# GOOGLE_CALENDAR_SCOPE=https://www.googleapis.com/auth/calendar.readonly

# Sheet ID for OKRs/KRs sync (Release 3)
# GOOGLE_OKR_SHEET_ID=

# -----------------------------------------------------------------------------
# VERCEL (set in Vercel dashboard, not in local .env)
# Required from: Release 1 deployment
# Status: pending_creation
# -----------------------------------------------------------------------------
# VERCEL_URL — auto-injected by Vercel, do not set manually
# VERCEL_ENV — auto-injected (production | preview | development)

# -----------------------------------------------------------------------------
# SLACK (optional / future)
# Required from: Release 5+ if activated
# Status: not_needed_yet
# -----------------------------------------------------------------------------
# SLACK_WEBHOOK_URL=
